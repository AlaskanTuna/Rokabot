{
  "name": "rokabot",
  "version": "0.1.0",
  "description": "Server-wide Discord character chatbot embodying Maniwa Roka, powered by Gemini 3.5 Flash Lite via Google ADK",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "LOG_LEVEL=debug tsx watch src/index.ts",
    "dev:quiet": "LOG_LEVEL=debug ADK_QUIET=1 tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "lint": "biome check .",
    "format": "biome check --write . && prettier --write .",
    "format:check": "biome check . && prettier --check .",
    "prepare": "husky || true",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:chat": "tsx scripts/test-chat.ts",
    "test:smoke": "tsx scripts/test-adk-smoke.ts",
    "test:features": "tsx scripts/test-features.ts",
    "test:phase8": "tsx scripts/test-phase8.ts",
    "test:memory": "tsx scripts/test-memory-extraction.ts"
  },
  "dependencies": {
    "@google/adk": "^0.1.0",
    "@google/genai": "^1.0.0",
    "better-sqlite3": "^12.9.0",
    "discord.js": "^14.26.4",
    "dotenv": "^16.5.0",
    "js-yaml": "^4.1.1",
    "pino": "^9.6.0",
    "sharp": "^0.34.5",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@commitlint/cli": "^21.2.1",
    "@commitlint/config-conventional": "^21.2.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/js-yaml": "^4.0.9",
    "husky": "^9.1.7",
    "lint-staged": "^17.1.0",
    "pino-pretty": "^13.0.0",
    "prettier": "^3.8.3",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0",
    "vitest": "^3.1.0"
  },
  "lint-staged": {
    "*.{ts,js}": "biome check --write --no-errors-on-unmatched",
    "*.{json,md,yml,yaml}": "prettier --write"
  },
  "engines": {
    "node": ">=24.13.0"
  }
}
