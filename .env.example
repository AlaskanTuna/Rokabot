# Required secrets (tunables are in config.yml)
DISCORD_TOKEN=
DISCORD_CLIENT_ID=
GEMINI_API_KEY=

# Optional: development guild ID for instant guild-scoped slash-command registration
DISCORD_DEV_GUILD_ID=

# Optional: dev key used by the harness for opt-in live runs (--live); never use GEMINI_API_KEY there
GRAPHIFY_GEMINI_API_KEY=

# Optional: SQLite database path override (use :memory: for isolated harness runs)
ROKABOT_DB_PATH=

# Optional: Tavily API key for web search (free: 1000 queries/month)
# Sign up at https://tavily.com to get a key
TAVILY_API_KEY=
